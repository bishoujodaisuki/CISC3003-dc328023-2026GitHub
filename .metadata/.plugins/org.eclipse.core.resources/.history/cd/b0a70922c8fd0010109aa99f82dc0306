
header {
    color: white;
    background-color: #1A237E;
    margin: 0em 4em 0.25em 4em;
}

header h1 {
	font-family: sans-serif; 
    font-size: 1.5em;
    font-weight: bold;
    margin-bottom: 0.3em;
}

header p {
    font-style: italic;
    font-weight: 300;
}

nav ul {
	text-decoration: underline;
	color: #00B0FF;
    list-style-type: none;
    margin: 1em 0;
    background-color: #3F51B5;
}

nav li {
	text-decoration: underline;
	color: #00B0FF;
    display: inline-block;
    margin: 0 1em;
}

nav a {
    text-decoration: underline;
    color: #00B0FF;
    font-weight: bold;
}

nav a:hover {
    background-color: #F50057;
    color: white; 
}

main {
    margin: 0 4em;
    padding: 1em;
}

section {
    margin: 2em 0;
}

.gallery {
    display: flex;
    justify-content: center;
    gap: 1em;
    flex-wrap: wrap;
    margin: 1em 0;
}

.gallery img {
    width: 150px;
    height: 100px;
    object-fit: cover;
    cursor: pointer;
    border: 2px solid #ddd;
    border-radius: 4px;
}

.gallery img:hover {
    border-color: #1A237E;
}

.large-image {
    text-align: center;
    margin: 2em 0;
}

.large-image img {
    max-width: 100%;
    max-height: 400px;
    border: 1px solid #ddd;
    border-radius: 8px;
}

.review {
    border: 1px solid #ddd;
    padding: 1em;
    margin: 1em 0;
    border-radius: 4px;
    background-color: #f9f9f9;
}

.review p:last-child {
    font-style: italic;
    color: #666;
    text-align: right;
}

footer {
    color: white;
    background-color: #1A237E;
    margin: 0em 4em 0.25em 4em;
}